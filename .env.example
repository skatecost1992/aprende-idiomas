# Copia este archivo como .env y rellena los valores reales.
# Las variables expuestas al front-end DEBEN empezar por VITE_.

# URL base de la API del backend
VITE_API_URL=http://localhost:4000/api

# Servicio que consulta las tasas (CDT, hipotecas) en la web y devuelve JSON.
# Si se define, el botón "Actualizar" del apartado Inversiones lo usa.
#   GET {VITE_RATES_API}/cdt        y   GET {VITE_RATES_API}/hipotecas
VITE_RATES_API=http://localhost:4000/api/tasas

# Llave pública de la pasarela de pago (Wompi / ePayco / PayU soportan PSE en Colombia)
VITE_PAYMENT_PUBLIC_KEY=pub_test_xxxxxxxxxxxx

# --- Solo backend (NO exponer al front, sin prefijo VITE_) ---
# PORT=4000
# DATABASE_URL=postgresql://user:pass@localhost:5432/aprende
# JWT_SECRET=cambia-esto-por-un-secreto-largo
# PAYMENT_PRIVATE_KEY=prv_test_xxxxxxxxxxxx
# PAYMENT_EVENTS_SECRET=xxxxxxxx   # para validar la firma de los webhooks
